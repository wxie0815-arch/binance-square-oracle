# 复制此文件为 .env 并填入你的密钥
# cp .env.example .env

# ==================== AI 模型 API 配置 ====================
# ==================== AI模型API配置 ====================
# 支持所有主流AI大模型API：OpenAI、Anthropic Claude、Google Gemini、DeepSeek等

# 主AI API配置（必需）
AI_API_URL=your_ai_api_url_here          # OpenAI兼容API端点
AI_API_KEY=your_ai_api_key_here          # API密钥
AI_MODEL=your_ai_model_name_here         # 模型名称

# 备用AI API配置（可选）
AI_API_URL_BACKUP=your_backup_api_url_here
AI_API_KEY_BACKUP=your_backup_api_key_here
AI_MODEL_BACKUP=your_backup_model_name_here

# 向后兼容：pucode LLM API Key（如果已设置，将自动使用）
# 注意：建议使用通用的AI_API_KEY配置
PUCODE_API_KEY=your_pucode_api_key_here
PUCODE_API_KEY_GPT=your_pucode_gpt_api_key_here

# ==================== L6 风格分析器配置 ====================
# 风格来源用户（可选，默认抓取官方基准风格）
STYLE_SOURCE_USER=binance_square_official
# 风格指纹缓存有效期（小时，默认48）
STYLE_FINGERPRINT_TTL_HOURS=48
# 帖子样本缓存有效期（小时，默认12）
STYLE_SAMPLE_TTL_HOURS=12

# ==================== 币安广场配置 ====================
# 币安广场 OpenAPI Key（在广场开发者后台获取）
SQUARE_API_KEY=your_square_openapi_key_here

# ==================== 6551 API 配置 ====================
# 6551 API Token（新闻+Twitter数据）
TOKEN_6551=your_6551_token_here
API_6551_BASE=your_6551_api_base_url_here

# ==================== 通知系统配置 ====================
# 方式1: OpenClaw message工具（推荐，支持所有通信工具）
NOTIFY_ENABLED=true                          # 是否启用通知
NOTIFY_CHANNEL=telegram                      # 通信工具：telegram|whatsapp|discord|irc|googlechat|slack|signal|imessage
NOTIFY_TARGET=your_chat_id_or_username_here  # 目标ID/用户名/频道名

# 方式2: Telegram Bot（向后兼容）
TG_BOT_TOKEN=your_telegram_bot_token_here
TG_CHAT_ID=your_telegram_chat_id_here

# 方式3: Webhook（通用）
WEBHOOK_URL=your_webhook_url_here
