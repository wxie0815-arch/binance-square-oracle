# Binance Square Oracle v1.0 — Environment Variables
# Copy this file to .env and fill in your keys.
# cp .env.example .env

# ==================== Optional: Square Publishing ====================
# Binance Square OpenAPI Key (get from Square developer dashboard)
# Enables automatic article publishing to Binance Square
SQUARE_API_KEY=your_square_openapi_key_here

# ==================== Optional: 6551 News Enhancement ====================
# 6551 API Token (enables hot news + KOL tweet signals)
TOKEN_6551=your_6551_token_here
API_6551_BASE=https://api.6551.io/v1

# ==================== Optional: LLM Model Override ====================
# Override the default LLM model (default: gpt-4.1-mini via OpenClaw)
# OPENCLAW_MODEL=gpt-4.1-mini
