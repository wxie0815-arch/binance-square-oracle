# Binance Square Oracle v1.1 environment variables
# Copy to .env and fill in what you need for local prototype mode.

# ==================== Local LLM Prototype ====================
# Required only for local Python prototype mode.
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# ==================== Optional: Square Publishing ====================
SQUARE_API_KEY=your_square_openapi_key_here

# ==================== Optional: 6551 News Enhancement ====================
TOKEN_6551=your_6551_token_here
API_6551_BASE=https://api.6551.io/v1
